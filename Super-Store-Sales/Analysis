--- Customer segmentation ---------- Q12
SELECT 
CUSTOMER_NAME,
concat('#', format(SUM(SALES), 2)) AS Total_Revenue,
	CASE 
		WHEN sum(sales)> 5000 THEN 'HIGH'
		WHEN sum(sales) BETWEEN 2000 AND 5000 THEN 'MEDIUM'
		ELSE 'LOW'
END AS CUS_SEGMENTATION
FROM superstore
GROUP BY CUSTOMER_NAME 
LIMIT 5;

--- Profitability by category ---------- Q13
SELECT
category,
concat('#', format(sum(sales), 2)) as Total_Revenue,
concat('#', format(sum(profit),2)) as Total_Profit,
concat(format(sum(profit)/sum(sales) * 100, 2), '%') as Profit_margin
from superstore
group by category
order by total_profit asc;

--- Customer loyalty ---------- Q13
SELECT Customer_Name, 
count(distinct Order_ID) as Total_Order
from superstore
group by Customer_Name;














---- Month over Month Growth ---------- long method
with monthlysales as
(
select year(Order_Date) as Year,
month(Order_Date) as Month,
sum(sales) as Monthly_sales
from superstore
group by Year(Order_Date), Month(Order_Date)
)
select Year,
Month,
concat('#', format (Monthly_Sales, 2)) as Monthly_sale,

	concat('#', format(lag(Monthly_sales) over 
		(order by Year, Month), 2)) as Pre_Month,
        
	concat(format((Monthly_sales - lag(Monthly_sales) over (order by Year, Month))
				/
   lag(Monthly_sales) over (order by Year, Month)
				* 100, 2), '%')
                as Growth_Percent,
    Case 
    when lag(monthly_sales) over (order by year, month) is null then '_'      
    when monthly_sales > lag(monthly_sales) over (order by year, month) then 'Grow'
    when monthly_sales < lag(monthly_sales) over (order by year, month) then 'Decline'
    else 'No change'
end as Trend
		from monthlysales
        order by year, month;


